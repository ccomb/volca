-- Example cabal.project.local for PETSc integration
-- Copy this to cabal.project.local and adjust paths as needed

-- PETSc paths (adjust to your installation)
extra-lib-dirs:
    /usr/local/petsc/lib

extra-include-dirs:
    /usr/local/petsc/include

-- Alternative: Use environment variables
-- extra-lib-dirs: ${PETSC_DIR}/${PETSC_ARCH}/lib
-- extra-include-dirs: ${PETSC_DIR}/${PETSC_ARCH}/include

-- Local petsc-hs dependency
packages: ., ../petsc-hs
